<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060C18"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GPS TRACKER"
                    android:textColor="#3B8BFF"
                    android:textSize="11sp"
                    android:letterSpacing="0.18"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Live Location"
                    android:textColor="#E8F0FB"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● ACTIVE"
                android:textColor="#3DD68C"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:fontFamily="monospace"
                android:background="@drawable/bg_pill_green"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#0D1626"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COORDINATES"
                    android:textColor="#3B8BFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tv_labellat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LATITUDE"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_lat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000000"
                            android:textColor="#E8F0FB"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="14dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/tv_labellon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LONGITUDE"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_lon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.000000"
                            android:textColor="#E8F0FB"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tv_labelaltitude"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALT"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_altitude"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="#E8F0FB"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="12dp"
                        android:layout_marginEnd="6dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/tv_labelaccuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACC"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_accuracy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="#E8F0FB"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="12dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/tv_labelspeed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SPD"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_speed"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="#E8F0FB"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:id="@+id/tv_lbladdress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADDRESS"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_address"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#E8F0FB"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:orientation="vertical"
                        android:background="@drawable/bg_data_block"
                        android:padding="14dp"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:id="@+id/tv_lbltime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="UPDATED AT"
                            android:textColor="#5A7099"
                            android:textSize="9sp"
                            android:letterSpacing="0.12"
                            android:fontFamily="monospace" />

                        <TextView
                            android:id="@+id/tv_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—:—"
                            android:textColor="#E8F0FB"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#0D1626"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETTINGS"
                    android:textColor="#3B8BFF"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_data_block"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location Updates"
                            android:textColor="#E8F0FB"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_updates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Off"
                            android:textColor="#5A7099"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_locationsupdates"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:theme="@style/SwitchBlue" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_data_block"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPS / Save Power"
                            android:textColor="#E8F0FB"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_labelsensor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Sensor mode"
                            android:textColor="#5A7099"
                            android:textSize="11sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_sensor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_pill_blue"
                                android:fontFamily="monospace"
                                android:paddingStart="10dp"
                                android:paddingTop="4dp"
                                android:paddingEnd="10dp"
                                android:paddingBottom="4dp"
                                android:text="Cell Tower + WiFi"
                                android:textColor="#3B8BFF"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_gps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:theme="@style/SwitchBlue" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_data_block"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Discord Integration"
                            android:textColor="#E8F0FB"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_discord_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="On"
                            android:textColor="#5A7099"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/sw_discord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:theme="@style/SwitchBlue" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#0D1626"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WAYPOINTS"
                        android:textColor="#3B8BFF"
                        android:textSize="10sp"
                        android:letterSpacing="0.15"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/wp_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Saved points"
                        android:textColor="#E8F0FB"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_wp"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:text="0"
                    android:textColor="#3B8BFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:background="@drawable/bg_circle_blue" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_close_app"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Close Application"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#FF5252"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_route_list"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Route Collection"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#0D1626"
            app:strokeColor="#FF9800"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_wp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ New Waypoint"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#3B8BFF"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_showp"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Waypoint List"
            android:textColor="#3B8BFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#0D1626"
            app:strokeColor="#3B8BFF"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="10dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/bt_showmap"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Show Map"
            android:textColor="#0A1628"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            app:backgroundTint="#3DD68C"
            app:cornerRadius="16dp"
            app:elevation="0dp"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
